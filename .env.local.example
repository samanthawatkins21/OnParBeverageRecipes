PROVI_API_KEY=your_provi_api_key_here
PROVI_API_BASE_URL=https://your-provi-api-base-url-here

# Optional if your Provi API uses non-default naming.
# Defaults:
# PROVI_API_SEARCH_PATH=/products
# PROVI_API_SEARCH_PARAM=q
# PROVI_API_KEY_HEADER=x-api-key
# PROVI_API_AUTH_MODE=header
# PROVI_API_AUTH_PREFIX=Bearer

# Example bearer-token style:
# PROVI_API_AUTH_MODE=bearer
# PROVI_API_SEARCH_PATH=/v1/products/search
